# Test environment
VITE_USER_NODE_ENV = test

# Public base path
VITE_PUBLIC_PATH = /

# Router mode
# Optional: hash | history
VITE_ROUTER_MODE = hash

# Build compression
# Optional: gzip | brotli | none
VITE_BUILD_COMPRESS = none

# Delete origin files after compression
VITE_BUILD_COMPRESS_DELETE_ORIGIN_FILE = false

# Drop console in build
VITE_DROP_CONSOLE = true

# Enable VitePWA
VITE_PWA = false

# Gateway serves same-origin /auth and /api/v1 paths in deployed environments.
VITE_API_URL = ""
